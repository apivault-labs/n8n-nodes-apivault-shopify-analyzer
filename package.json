{
  "name": "n8n-nodes-apivault-shopify-analyzer",
  "version": "0.1.0",
  "description": "n8n community node for Shopify Store Analyzer — spy on any Shopify store: estimated revenue, traffic, brand age, tech stack (60+ apps), tracking IDs (GTM/GA4/FB Pixel), active promo codes, dropshipper risk, customer segment and international expansion. StoreLeads.app alternative. CSV-ready JSON. No login. Pay-as-you-go, no monthly fee.",
  "license": "MIT",
  "homepage": "https://apify.com/apivault_labs/shopify-store-analyzer",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "shopify-scraper",
    "shopify-analyzer",
    "ecommerce-intelligence",
    "competitor-analysis",
    "revenue-estimate",
    "tech-stack-detection",
    "storeleads-alternative",
    "lead-generation",
    "dropshipping",
    "apify"
  ],
  "author": {
    "name": "apivault_labs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/apivault-labs/n8n-nodes-apivault-shopify-analyzer.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && copyfiles \"nodes/**/*.svg\" dist",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ApifyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ShopifyAnalyzer/ShopifyAnalyzer.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "copyfiles": "^2.4.1",
    "n8n-workflow": "*",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
